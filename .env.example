TWITTER_ACCESS_TOKEN=                 # Access Token (your account)
TWITTER_ACCESS_TOKEN_SECRET=          # Access Token Secret (your account)
TWITTER_BEARER_TOKEN=                 # Bearer Token (for read-only search/lookup)

# Dashboard
DASHBOARD_SECRET=                     # Secret token for ?token= auth on the visual dashboard
