# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Required: GPT-4o powers task analysis, execution, and all skill outputs
OPENAI_API_KEY=sk-...

# ─── Moltlaunch wallet ───────────────────────────────────────────────────────
# Generated on first startup — add these to Railway after first run
AGENT_ADDRESS=0x...
MOLTLAUNCH_PRIVATE_KEY=0x...

# ─── Moltlaunch API ──────────────────────────────────────────────────────────
# Optional override — defaults to https://api.moltlaunch.com
MOLTLAUNCH_API_URL=https://api.moltlaunch.com

# ─── Discord notifications ───────────────────────────────────────────────────
# Webhook URL for the CashClaw #engineering Discord channel
# Create at: Discord Server Settings → Integrations → Webhooks
DISCORD_ENGINEERING_WEBHOOK=https://discord.com/api/webhooks/...

# ─── Brave Search (optional) ─────────────────────────────────────────────────
# Used for competitor research web searches — works without it but results improve
BRAVE_SEARCH_API_KEY=BSA...
